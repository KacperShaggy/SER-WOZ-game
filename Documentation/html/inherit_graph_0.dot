digraph "Graphical Class Hierarchy"
{
 // LATEX_PDF_SIZE
  bgcolor="transparent";
  edge [fontname=Helvetica,fontsize=10,labelfontname=Helvetica,labelfontsize=10];
  node [fontname=Helvetica,fontsize=10,shape=box,height=0.2,width=0.4];
  rankdir="LR";
  Node0 [id="Node000000",label="MonoBehaviour",height=0.2,width=0.4,color="grey60", fillcolor="#E0E0E0", style="filled",tooltip=" "];
  Node0 -> Node1 [id="edge1_Node000000_Node000001",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node1 [id="Node000001",label="ActiveTower",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_active_tower.html",tooltip="Controls an active tower that fires bullets in a patterned sequence."];
  Node0 -> Node2 [id="edge2_Node000000_Node000002",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node2 [id="Node000002",label="Bullet",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_bullet.html",tooltip="Represents a projectile fired by a tower."];
  Node0 -> Node3 [id="edge3_Node000000_Node000003",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node3 [id="Node000003",label="CameraMovement",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_camera_movement.html",tooltip="Controls automatic back-and-forth camera movement."];
  Node0 -> Node4 [id="edge4_Node000000_Node000004",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node4 [id="Node000004",label="Enemy",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_enemy.html",tooltip="Represents an enemy unit that moves toward a target carriage."];
  Node0 -> Node5 [id="edge5_Node000000_Node000005",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node5 [id="Node000005",label="GroundRow",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_ground_row.html",tooltip="Controls the movement and lifecycle of a ground row segment."];
  Node0 -> Node6 [id="edge6_Node000000_Node000006",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node6 [id="Node000006",label="MapGenerating",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_map_generating.html",tooltip="Responsible for procedural generation of ground rows and map elements."];
  Node0 -> Node7 [id="edge7_Node000000_Node000007",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node7 [id="Node000007",label="Spawner",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_spawner.html",tooltip="Responsible for periodically spawning enemy units around the map."];
  Node0 -> Node8 [id="edge8_Node000000_Node000008",dir="back",color="steelblue1",style="solid",tooltip=" "];
  Node8 [id="Node000008",label="Tower",height=0.2,width=0.4,color="grey40", fillcolor="white", style="filled",URL="$class_tower.html",tooltip="Represents a defensive tower that detects enemies and shoots at them."];
}
